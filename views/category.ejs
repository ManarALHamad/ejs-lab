<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= category %></title>
</head>


 <%- include('./partials/nav') %>

<body>


   

   <% menuItems.forEach(function(item){ %>

       <% if(item.category === "mains"){ %>
        
        <h3> <%= item.name %></h3>

        <p>  💰 <%= item.price %> </p>

        <p>  ⭐️ <%= item.rating %> </p>

        <p>  <%= item.details %> </p>
        <%} %>
    

   <% }) %>


   

   <% menuItems.forEach(function(item){ %>

       <% if(item.category === "desserts"){ %>
      
        <h3> <%= item.name %></h3>

        <p>  💰 <%= item.price %> </p>

        <p>  ⭐️ <%= item.rating %> </p>

        <p>  <%= item.details %> </p>
        <%} %>
    

   <% }) %>


   <% menuItems.forEach(function(item){ %>

       <% if(item.category === "sides"){ %>
       
        <h3> <%= item.name %></h3>

        <p>  💰 <%= item.price %> </p>

        <p>  ⭐️ <%= item.rating %> </p>

        <p>  <%= item.details %> </p>
        <%} %>
    

   <% }) %>

 


    
</body>
</html>